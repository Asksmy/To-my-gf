    <stop offset="0%" stop-color="#C0152A"/>
    <stop offset="100%" stop-color="#4a000c"/>
  </linearGradient>
  <filter id="sombra">
    <feDropShadow dx="0" dy="3" stdDeviation="3.5" flood-color="#8B0B1A" flood-opacity=".5"/>
  </filter>
  <filter id="sombraT">
    <feDropShadow dx="2" dy="6" stdDeviation="6" flood-color="#000" flood-opacity=".4"/>
  </filter>
</defs>

