<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Para ti, mi niña 🌹</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,600&family=Lato:wght@300;400&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body { width: 100%; min-height: 100vh; overflow-x: hidden; }

  body {
    background: linear-gradient(160deg, #1a0008 0%, #3d0015 35%, #1a0008 70%, #0d0005 100%);
    font-family: 'Lato', sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1rem 4rem;
    position: relative;
  }

  /* ── Pétalos de fondo ── */
  .petalo-bg {
    position: fixed; top: -60px;
    opacity: 0; pointer-events: none; z-index: 0;
    animation: caer linear infinite;
  }
  @keyframes caer {
    0%   { transform: translateY(0) rotate(0deg);   opacity: 0; }
    5%   { opacity: 0.7; }
    90%  { opacity: 0.45; }
    100% { transform: translateY(110vh) rotate(560deg); opacity: 0; }
  }

  /* ── Orbes ── */
  .orb {
    position: fixed; border-radius: 50%;
    pointer-events: none; z-index: 0; filter: blur(80px);
    animation: orbF ease-in-out infinite alternate;
  }
  .orb1{ width:340px;height:340px;background:rgba(192,21,42,.18);top:3%;left:-10%;animation-duration:9s; }
  .orb2{ width:260px;height:260px;background:rgba(232,51,74,.12);top:55%;right:-8%;animation-duration:12s;animation-delay:3s; }
  .orb3{ width:200px;height:200px;background:rgba(255,180,190,.08);bottom:8%;left:18%;animation-duration:7s;animation-delay:1s; }
  @keyframes orbF { from{transform:translateY(0) scale(1);} to{transform:translateY(-28px) scale(1.07);} }

  /* ── Título ── */
  .titulo-wrap {
    position: relative; z-index: 2;
    text-align: center;
    margin-bottom: clamp(1rem, 3vw, 2rem);
    animation: fadeDown 1.2s ease both;
  }
  .titulo-wrap h1 {
    font-family: 'Playfair Display', serif; font-style: italic;
    font-size: clamp(1.7rem, 5.5vw, 3.2rem);
    color: #fff; text-shadow: 0 2px 24px rgba(192,21,42,.7);
    letter-spacing: .02em;
  }
  .subtitulo {
    font-family:'Lato',sans-serif; font-weight:300;
    color:#FFCDD5; font-size:clamp(.68rem,2vw,.9rem);
    letter-spacing:.22em; text-transform:uppercase; margin-top:.35rem;
  }
  @keyframes fadeDown { from{opacity:0;transform:translateY(-28px);} to{opacity:1;transform:translateY(0);} }
  @keyframes fadeUp   { from{opacity:0;transform:translateY(36px);} to{opacity:1;transform:translateY(0);} }

  /* ── Ramo SVG ── */
  .escena {
    position: relative; z-index: 2;
    width: min(500px, 92vw);
    animation: fadeUp 1.4s ease .3s both;
  }
  .ramo-svg {
    width: 100%; display: block;
    filter: drop-shadow(0 12px 40px rgba(192,21,42,.5));
  }

  /* Animaciones de flores: oscilación suave desde la BASE de cada flor */
  .f1 { transform-origin: 240px 390px; animation: sw 4.2s ease-in-out infinite alternate; }
  .f2 { transform-origin: 155px 360px; animation: sw 5.0s ease-in-out .6s infinite alternate; }
  .f3 { transform-origin: 325px 360px; animation: sw 4.7s ease-in-out .3s infinite alternate; }
  .f4 { transform-origin: 100px 330px; animation: sw 3.9s ease-in-out 1.0s infinite alternate; }
  .f5 { transform-origin: 380px 330px; animation: sw 4.5s ease-in-out .8s infinite alternate; }
  .f6 { transform-origin:  60px 305px; animation: sw 5.3s ease-in-out .2s infinite alternate; }
  .f7 { transform-origin: 420px 305px; animation: sw 4.0s ease-in-out 1.4s infinite alternate; }
  .fc1{ transform-origin: 190px 345px; animation: sw 4.8s ease-in-out .5s infinite alternate; }
  .fc2{ transform-origin: 290px 345px; animation: sw 3.7s ease-in-out 1.1s infinite alternate; }
  @keyframes sw { from{transform:rotate(-3deg);} to{transform:rotate(3deg);} }

  .brillar { animation: bri 3s ease-in-out infinite; }
  @keyframes bri { 0%,100%{opacity:1;} 50%{opacity:.6;} }

  .lazo { transform-origin: 240px 435px; animation: latir 2.6s ease-in-out infinite; }
  @keyframes latir { 0%,100%{transform:scale(1);} 50%{transform:scale(1.04);} }

  /* ── Mensajes ── */
  .mensajes {
    position:relative; z-index:2;
    display:flex; flex-direction:column; gap:clamp(.9rem,2.5vw,1.4rem);
    width:min(500px,92vw); margin-top:clamp(1rem,2.5vw,1.8rem);
    animation: fadeUp 1.4s ease .7s both;
  }
  .sep {
    display:flex; align-items:center; justify-content:center;
    gap:.6rem; color:rgba(192,21,42,.5); font-size:.7rem; letter-spacing:.3em;
  }
  .sep::before,.sep::after {
    content:''; flex:1; height:1px;
    background:linear-gradient(to right,transparent,rgba(192,21,42,.4),transparent);
  }
  .mcard {
    background:rgba(255,255,255,.04);
    border:1px solid rgba(192,21,42,.35);
    border-radius:16px;
    padding:clamp(.9rem,3vw,1.5rem) clamp(1.1rem,3.5vw,1.8rem);
    backdrop-filter:blur(10px); position:relative; overflow:hidden;
  }
  .mcard::before {
    content:''; position:absolute; top:0; left:0;
    width:4px; height:100%;
    background:linear-gradient(to bottom,#E8334A,#8B0B1A);
    border-radius:4px 0 0 4px;
  }
  .mcard p {
    font-family:'Playfair Display',serif; font-style:italic;
    color:#FFF5F5; font-size:clamp(.86rem,2.4vw,1.02rem);
    line-height:1.78; text-align:center;
  }
  .mcard .ico { display:block; font-size:clamp(1.1rem,3.5vw,1.5rem); margin-bottom:.45rem; text-align:center; }

  .firma {
    position:relative; z-index:2; text-align:center;
    margin-top:clamp(1.2rem,3vw,2rem);
    animation: fadeUp 1.4s ease 1s both;
  }
  .firma span { font-family:'Playfair Display',serif; font-style:italic; color:rgba(255,255,255,.28); font-size:clamp(.72rem,1.8vw,.88rem); letter-spacing:.12em; }

  @media(prefers-reduced-motion:reduce){
    .petalo-bg,.f1,.f2,.f3,.f4,.f5,.f6,.f7,.fc1,.fc2,.lazo,.brillar,.orb{animation:none;}
  }
</style>
</head>
<body>

