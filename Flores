    <stop offset="100%" stop-color="#ffc96e"/>
  </radialGradient>
  <linearGradient id="gTallo" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%" stop-color="#1A3A2A"/>
    <stop offset="50%" stop-color="#2D5A3D"/>
    <stop offset="100%" stop-color="#1A3A2A"/>
