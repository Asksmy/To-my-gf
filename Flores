<script>
(function(){
  const cols=['#C0152A','#E8334A','#ff6b7a','#ffffff','#ffcdd5','#8B0B1A','#ff8a96'];
  const n = window.innerWidth < 480 ? 16 : 28;
  for(let i=0;i<n;i++){
    const d=document.createElement('div');
    d.className='petalo-bg';
    d.style.left=Math.random()*100+'vw';
    d.style.background=cols[Math.floor(Math.random()*cols.length)];
    d.style.animationDuration=(7+Math.random()*12)+'s';
    d.style.animationDelay=(Math.random()*14)+'s';
    d.style.width=(8+Math.random()*9)+'px';
    d.style.height=(12+Math.random()*13)+'px';
    d.style.borderRadius=Math.random()>.5?'50% 0 50% 0':'50% 50% 0 50%';
    document.body.appendChild(d);
  }
})();
</script>

<div class="titulo-wrap">
  <h1>Para ti, mi niña 🌹</h1>
  <p class="subtitulo">con todo el amor del mundo</p>
</div>

